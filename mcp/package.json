{
  "name": "@jayofemi/ai-checker",
  "version": "1.0.0",
  "mcpName": "io.github.JayOfemi/byakugan",
  "description": "Private, on-device AI-text analysis (detection, AI-tell spans, reuse overlap) as a TypeScript library and an MCP server.",
  "license": "MIT",
  "author": "Jay Ofemi",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ai-checker-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayOfemi/byakugan.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/JayOfemi/byakugan#readme",
  "bugs": {
    "url": "https://github.com/JayOfemi/byakugan/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "node dist/server.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai-detection",
    "ai-text",
    "writing",
    "privacy",
    "on-device",
    "mcp",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "harper.js": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
