{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"outDir": "./node_modules/.tmp",
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"composite": true,
		"emitDeclarationOnly": true,
		"types": ["node"]
	},
	"include": ["vite.config.ts"]
}
